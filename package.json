{
  "name": "kindred-home",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "lint": "eslint 'kin/**/*.js'",
    "lint:fix": "eslint 'kin/**/*.js' --fix",
    "format": "prettier --write 'kin/**/*.js' '**/*.css'",
    "prepare": "node -e \"process.exit(process.env.CI ? 0 : 1)\" || husky"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "eslint": "^9.0.0",
    "globals": "^16.0.0",
    "husky": "^9.0.0",
    "lint-staged": "^15.0.0",
    "prettier": "^3.0.0"
  },
  "lint-staged": {
    "kin/**/*.js": [
      "eslint --fix",
      "prettier --write"
    ],
    "**/*.css": [
      "prettier --write"
    ]
  }
}
